---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "AV MEDIA | Boutique Video Agency",
  description = "Gallery-first cinematic portfolio for AV MEDIA with static Astro performance architecture."
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#121212" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="bg-deepCharcoal text-ivoryFog antialiased">
    <div class="page-shell">
      <slot />
    </div>
  </body>
</html>
