---
import ContactFormIsland from "../components/ContactFormIsland";
import VideoReelIsland from "../components/VideoReelIsland";
import MainLayout from "../layouts/MainLayout.astro";

const socialProof = ["Daughters of Charity", "AV SaaS", "AV Events"];

const services = [
  "Digital Transformation (Web/ERP)",
  "Content Strategy (High-End Video)"
];
---

<MainLayout
  title="High-Ticket Agency Portfolio 2026"
  description="We architect digital infrastructure and conversion video systems for Africa's leaders."
>
  <main>
    <section class="section-frame pt-12 md:pt-20">
      <div class="fade-rise grid gap-10 lg:grid-cols-[1.15fr_0.85fr] lg:items-end">
        <div>
          <p class="eyebrow">High-Ticket Agency Portfolio 2026</p>
          <h1 class="section-title max-w-3xl text-balance">
            We Architect the Digital Infrastructure for Africa&apos;s Leaders.
          </h1>
          <p class="mt-6 max-w-2xl text-lg text-plumNoir/75 md:text-xl">
            Full-stack systems and high-conversion video strategy for NGOs and Retailers.
          </p>
          <div class="mt-8 flex flex-wrap gap-4">
            <a href="#contact" class="cta-pill">Secure Your Strategy Session</a>
            <a
              href="#case-study"
              class="inline-flex items-center justify-center rounded-full border border-plumNoir/25 px-6 py-3 text-sm font-semibold uppercase tracking-[0.08em]"
            >
              View NGO Transformation
            </a>
          </div>
        </div>

        <div class="surface-card fade-rise delay-1 grid-stripes bg-white/65">
          <p class="text-sm uppercase tracking-[0.16em] text-plumNoir/60">Positioning</p>
          <p class="mt-4 text-2xl leading-snug text-plumNoir">
            Based in Tigray. Built for Global Standards. Powered by AI.
          </p>
          <p class="mt-4 text-sm text-plumNoir/70">
            Minimal interfaces, execution discipline, and system architecture that scales with trust.
          </p>
        </div>
      </div>
    </section>

    <section id="reel" class="section-frame pt-6">
      <div class="fade-rise delay-1">
        <p class="eyebrow">Interactive Reel</p>
        <h2 class="section-title">A 60-Second Proof of Taste and Velocity</h2>
        <p class="mt-4 max-w-3xl text-plumNoir/70">
          Add your optimized reel at /media/reel-60s.mp4. The island below keeps interaction isolated,
          while the rest of this page ships as static HTML.
        </p>
      </div>

      <div class="mt-8 fade-rise delay-2">
        <VideoReelIsland client:visible />
      </div>
    </section>

    <section id="social-proof" class="section-frame pt-0">
      <div class="surface-card fade-rise">
        <p class="eyebrow">Social Proof</p>
        <div class="grid gap-4 md:grid-cols-3">
          {socialProof.map((entity) => (
            <div class="rounded-2xl border border-plumNoir/15 bg-cloudDancer p-6">
              <p class="text-xs uppercase tracking-[0.18em] text-plumNoir/50">Trusted By</p>
              <h3 class="mt-3 text-2xl">{entity}</h3>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="case-study" class="section-frame pt-0">
      <div class="fade-rise">
        <p class="eyebrow">Case Study</p>
        <h2 class="section-title">The NGO Transformation (DOC)</h2>
        <p class="mt-4 max-w-3xl text-plumNoir/75">
          Real interface redesign with before-and-after architecture that improved decision velocity,
          accountability, and service delivery visibility.
        </p>
      </div>

      <div class="mt-8 grid gap-6 lg:grid-cols-2">
        <article class="surface-card">
          <p class="mb-4 text-xs font-bold uppercase tracking-[0.15em] text-plumNoir/60">Before</p>
          <picture>
            <source srcset="/media/doc-before.avif" type="image/avif" />
            <source srcset="/media/doc-before.webp" type="image/webp" />
            <img
              src="/media/doc-before.svg"
              alt="Legacy fragmented NGO dashboard"
              width="900"
              height="520"
              loading="lazy"
              decoding="async"
              fetchpriority="low"
              class="w-full rounded-2xl border border-plumNoir/10"
            />
          </picture>
        </article>

        <article class="surface-card">
          <p class="mb-4 text-xs font-bold uppercase tracking-[0.15em] text-plumNoir/60">After</p>
          <picture>
            <source srcset="/media/doc-after.avif" type="image/avif" />
            <source srcset="/media/doc-after.webp" type="image/webp" />
            <img
              src="/media/doc-after.svg"
              alt="Unified NGO operational dashboard"
              width="900"
              height="520"
              loading="lazy"
              decoding="async"
              fetchpriority="low"
              class="w-full rounded-2xl border border-plumNoir/10"
            />
          </picture>
        </article>
      </div>
    </section>

    <section id="services" class="section-frame pt-0">
      <div class="surface-card bg-plumNoir text-cloudDancer">
        <p class="eyebrow border-cloudDancer/20 text-cloudDancer/80">Services</p>
        <div class="grid gap-5 md:grid-cols-2">
          {services.map((service, index) => (
            <article class="rounded-2xl border border-cloudDancer/20 bg-white/5 p-6">
              <p class="text-xs uppercase tracking-[0.15em] text-cloudDancer/60">0{index + 1}</p>
              <h3 class="mt-3 text-2xl text-cloudDancer">{service}</h3>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="contact" class="section-frame pt-0">
      <div class="grid gap-8 lg:grid-cols-[1fr_1fr] lg:items-start">
        <div class="fade-rise">
          <p class="eyebrow">Value Proposition</p>
          <h2 class="section-title">
            Based in Tigray. Built for Global Standards. Powered by AI.
          </h2>
          <p class="mt-5 max-w-xl text-plumNoir/75">
            We design operating systems and media systems together, so your organization does not
            choose between trust and growth. You get both, engineered as one.
          </p>
        </div>

        <ContactFormIsland client:visible />
      </div>
    </section>
  </main>
</MainLayout>
