---
import MainLayout from "../layouts/MainLayout.astro";

const workItems = [
  {
    title: "Retail Launch Film",
    format: "9:16 Storyline",
    poster: "/media/work-01.webp",
    posterFallback: "/media/work-01.svg"
  },
  {
    title: "NGO Impact Reel",
    format: "Vertical Documentary",
    poster: "/media/work-02.webp",
    posterFallback: "/media/work-02.svg"
  },
  {
    title: "Founder Brand Cut",
    format: "Short-Form Conversion",
    poster: "/media/work-03.webp",
    posterFallback: "/media/work-03.svg"
  },
  {
    title: "Campaign Teaser",
    format: "Ad-Native Sequence",
    poster: "/media/work-04.webp",
    posterFallback: "/media/work-04.svg"
  }
];
---

<MainLayout
  title="AV MEDIA | Boutique Video Agency Portfolio"
  description="Cinematic strategy and gallery-first storytelling for brands that need engineered attention."
>
  <main class="cinema-page">
    <header class="nav-thin">
      <a class="brand-mark" href="#top">AV MEDIA</a>
      <a class="contact-link" href="#footer">CONTACT</a>
    </header>

    <section id="top" class="hero-cinema">
      <video
        class="hero-video"
        autoplay
        muted
        loop
        playsinline
        preload="none"
        poster="/media/hero-poster.webp"
        aria-label="AV MEDIA cinematic hero backdrop"
      >
        <source src="/media/hero-mobile.webm" type="video/webm" media="(max-width: 767px)" />
        <source src="/media/hero-mobile.mp4" type="video/mp4" media="(max-width: 767px)" />
        <source src="/media/hero-desktop.webm" type="video/webm" media="(min-width: 768px)" />
        <source src="/media/hero-desktop.mp4" type="video/mp4" media="(min-width: 768px)" />
      </video>
      <div class="hero-overlay" aria-hidden="true"></div>
      <div class="hero-center-copy">
        <p class="hero-kicker">AV MEDIA</p>
        <h1>CINEMATIC STRATEGY</h1>
      </div>
    </section>

    <section id="work-grid" class="gallery-wrap">
      <div class="gallery-grid">
        {workItems.map((item) => (
          <article class="work-card">
            <picture>
              <source srcset={item.poster.replace(".webp", ".avif")} type="image/avif" />
              <source srcset={item.poster} type="image/webp" />
              <img
                src={item.posterFallback}
                alt={`${item.title} visual preview`}
                width="540"
                height="960"
                loading="lazy"
                decoding="async"
              />
            </picture>
            <div class="work-meta">
              <p>{item.title}</p>
              <span>{item.format}</span>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section id="philosophy" class="philosophy-block">
      <h2>WE DON&apos;T JUST EDIT; WE ENGINEER ATTENTION.</h2>
    </section>

    <footer id="footer" class="footer-minimal">
      <a href="mailto:hello@avmedia.studio">hello@avmedia.studio</a>
      <div class="social-row">
        <a href="https://instagram.com" target="_blank" rel="noreferrer">Instagram</a>
        <a href="https://youtube.com" target="_blank" rel="noreferrer">YouTube</a>
        <a href="https://vimeo.com" target="_blank" rel="noreferrer">Vimeo</a>
      </div>
    </footer>
  </main>
</MainLayout>
